# GitHub repo that holds the site content + images
VITE_GH_OWNER=rfi-irfos
VITE_GH_REPO=e-techbike-at
# Fine-grained PAT: Contents Read+Write on the above repo only
VITE_GH_TOKEN=ghp_...

# Path inside the repo where the admin WRITES content + images.
# CRITICAL: this must be the path the Vite build actually serves, or admin
# saves go to a file the live site never loads (silent no-op).
#   - This repo (frontend under frontend/):  frontend/public/content.json
#   - A client repo with the frontend at root:  public/content.json
# Multilingual: the admin derives content.de.json / content.hu.json from this.
VITE_GH_CONTENT_PATH=frontend/public/content.json
VITE_GH_UPLOADS_DIR=frontend/public/uploads

# SHA-256 hash of the admin password — generate with: echo -n "yourpassword" | sha256sum
VITE_ADMIN_HASH=<hash-of-your-password>

# GitHub PAT is NOT stored here — enter it once at first login in the browser

# Web3Forms access key — get free at web3forms.com
VITE_WEB3FORMS_KEY=...

# Vite base path — '/' for custom domain, '/repo-name/' for github.io URL
VITE_BASE_URL=/
