# GitHub repo that holds the site content + images
VITE_GH_OWNER=rfi-irfos
VITE_GH_REPO=e-techbike-at

# Fine-grained PAT: Contents Read+Write on the above repo only
VITE_GH_TOKEN=ghp_...

# Path inside the repo to content.json (relative to repo root)
# Template repo: frontend/public/content.json
# Client repo (frontend at root): public/content.json
VITE_GH_CONTENT_PATH=public/content.json
VITE_GH_UPLOADS_DIR=public/uploads

# Admin panel password (shown to client, they keep it safe)
VITE_ADMIN_PASSWORD=changeme

# Web3Forms access key — get free at web3forms.com
VITE_WEB3FORMS_KEY=...

# Vite base path — '/' for custom domain, '/repo-name/' for github.io URL
VITE_BASE_URL=/
